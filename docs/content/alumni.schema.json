{
  "title": "RITE Alumni And Community Profile Content",
  "type": "object",
  "required": ["modelVersion", "countries", "functions", "profiles"],
  "properties": {
    "modelVersion": {
      "type": "string",
      "description": "Version date for the static preview content model."
    },
    "modelNotes": {
      "type": "object",
      "description": "Human-readable notes about preview model boundaries. Alumni/community profile records are not the same thing as authenticated site-member accounts.",
      "properties": {
        "en": { "type": "string" },
        "es": { "type": "string" }
      }
    },
    "countries": {
      "type": "object",
      "description": "Country filters and labels keyed by stable country id."
    },
    "functions": {
      "type": "object",
      "description": "Community function filters and labels keyed by stable function id."
    },
    "profiles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "country", "participation", "place", "summary"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Stable content id for the person profile. This is not an authentication account id."
          },
          "name": {
            "type": "string"
          },
          "country": {
            "type": "string",
            "description": "Primary country key used for country grouping."
          },
          "audiences": {
            "type": "array",
            "description": "Audience landing views that surface this profile (alumni, active, recruiting). Closed set. A profile with no audiences tag is treated as recruiting-visible by default. Program leaders are typically tagged for both alumni and recruiting since they are strong public-facing recruiting voices.",
            "items": { "type": "string", "enum": ["alumni", "active", "recruiting"] }
          },
          "participation": {
            "type": "array",
            "description": "One or more role/years records. A person's role can differ across years (e.g. teacher one year, host in later years, leader after that), so participation is not a single flat role list.",
            "items": {
              "type": "object",
              "required": ["role"],
              "properties": {
                "role": {
                  "type": "string",
                  "enum": ["leader", "host", "teacher"]
                },
                "years": {
                  "type": "array",
                  "items": { "type": "integer" },
                  "description": "Explicit discrete years this role was held (single year, or a list of specific non-contiguous years). Use `range` instead when the role spanned a known contiguous span."
                },
                "range": {
                  "type": "object",
                  "description": "A contiguous year span for this role, used instead of `years` when the role was held continuously and no unconfirmed transition year should be implied.",
                  "properties": {
                    "start": { "type": "integer" },
                    "end": { "type": "integer" }
                  }
                }
              }
            }
          },
          "participationYearNote": {
            "type": "object",
            "properties": {
              "en": { "type": "string" },
              "es": { "type": "string" }
            }
          },
          "place": {
            "type": "object",
            "required": ["en", "es"],
            "properties": {
              "en": { "type": "string" },
              "es": { "type": "string" }
            }
          },
          "summary": {
            "type": "object",
            "required": ["en", "es"],
            "properties": {
              "en": { "type": "string" },
              "es": { "type": "string" }
            }
          },
          "memories": {
            "type": "array",
            "description": "Optional public-preview memory snippets that can later become reviewed story submissions.",
            "items": {
              "type": "object",
              "required": ["title", "body"],
              "properties": {
                "title": {
                  "type": "object",
                  "properties": {
                    "en": { "type": "string" },
                    "es": { "type": "string" }
                  }
                },
                "body": {
                  "type": "object",
                  "properties": {
                    "en": { "type": "string" },
                    "es": { "type": "string" }
                  }
                }
              }
            }
          },
          "pictures": {
            "type": "array",
            "description": "Optional reviewed picture references for the future media archive. Static preview entries may be empty until media permissions are confirmed.",
            "items": {
              "type": "object",
              "required": ["caption"],
              "properties": {
                "src": { "type": "string" },
                "caption": {
                  "type": "object",
                  "properties": {
                    "en": { "type": "string" },
                    "es": { "type": "string" }
                  }
                },
                "year": { "type": "integer" },
                "approval": {
                  "type": "object",
                  "description": "Optional photo publication approval metadata.",
                  "properties": {
                    "status": { "type": "string" },
                    "confirmedBy": { "type": "string" },
                    "confirmationChannel": { "type": "string" },
                    "confirmedAt": { "type": "string" },
                    "scope": { "type": "string" }
                  }
                }
              }
            }
          },
          "suggestions": {
            "type": "array",
            "description": "Optional prompts or suggested additions for future profile enrichment.",
            "items": {
              "type": "object",
              "required": ["text"],
              "properties": {
                "text": {
                  "type": "object",
                  "properties": {
                    "en": { "type": "string" },
                    "es": { "type": "string" }
                  }
                }
              }
            }
          },
          "privacy": {
            "type": "string",
            "enum": ["public-preview", "needs-confirmation"]
          },
          "approval": {
            "type": "object",
            "description": "Optional publication approval metadata for public-preview profile fields.",
            "properties": {
              "status": { "type": "string" },
              "confirmedBy": { "type": "string" },
              "confirmationChannel": { "type": "string" },
              "confirmedAt": { "type": "string" },
              "scope": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
